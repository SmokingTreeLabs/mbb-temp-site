<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Responsive Full Width Layout</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: Arial, sans-serif;
      line-height: 1.6;
      background-color: #f4f4f4;
      color: #333;
    }

    .container {
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 20px;
    }

    header,
    footer {
      background-color: #004080;
      color: #fff;
      padding: 20px 20px;
      text-align: center;
    }

    nav {
      margin: 20px 0;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 10px;
    }

    nav a {
      color: #004080;
      text-decoration: none;
      background: #fff;
      border: 1px solid #004080;
      padding: 10px 15px;
      border-radius: 4px;
    }

    .layout {
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 20px;
    }

    .main-content,
    .sidebar {
      background: #fff;
      padding: 20px;
      border-radius: 8px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.1);
    }

    .main-content h1 {
      margin-bottom: 15px;
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 20px;
      margin-top: 20px;
    }

    .card {
      background: #fafafa;
      border: 1px solid #e0e0e0;
      padding: 15px;
      border-radius: 6px;
    }

    @media (max-width: 900px) {
      .layout {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 600px) {
      nav {
        flex-direction: column;
      }
      .cards {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <header>
    <div class="container">
      <h1>Responsive Full Width Layout</h1>
      <p>Simple page layout with a full-width container and responsive grid.</p>
    </div>
  </header>

  <main class="container">
    <nav>
      <a href="#">Home</a>
      <a href="#">About</a>
      <a href="#">Services</a>
      <a href="#">Contact</a>
    </nav>

    <div class="layout">
      <section class="main-content">
        <h1>Welcome</h1>
        <p>This layout adapts to different screen sizes using responsive CSS grid and flexible components.</p>
        <div class="cards">
          <div class="card">
            <h2>Card One</h2>
            <p>Content block with a brief description and supporting details.</p>
          </div>
          <div class="card">
            <h2>Card Two</h2>
            <p>Another content section to show how elements stack on smaller screens.</p>
          </div>
        </div>
      </section>

      <aside class="sidebar">
        <h2>Sidebar</h2>
        <p>Additional information, links or calls to action can be placed here.</p>
        <ul>
          <li>Responsive design</li>
          <li>Flexible layout</li>
          <li>Modern UI</li>
        </ul>
      </aside>
    </div>
  </main>

  <footer>
    <div class="container">
      <p>&copy; 2026 Responsive Page Example</p>
    </div>
  </footer>
  <script src='https://storage.ko-fi.com/cdn/scripts/overlay-widget.js'></script>
<script>
  kofiWidgetOverlay.draw('megabloodbath', {
    'type': 'floating-chat',
    'floating-chat.donateButton.text': 'Tip Me',
    'floating-chat.donateButton.background-color': '#323842',
    'floating-chat.donateButton.text-color': '#fff'
  });
</script>
</body>
</html>
